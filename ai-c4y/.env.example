OLLAMA_URL              = http://localhost:11434
OLLAMA_GENERAL_MODEL    = gemma3:12b
OLLAMA_CODE_MODEL       = qwen2.5-coder:14b
OLLAMA_EMBEDDING_MODEL  = nomic-embed-text:137m-v1.5-fp16
TOKENS_LENGTH           = 28000
CHARS_PER_TOKEN         = 3

OPENROUTER_API_KEY = your-open-router-api-key
OPENROUTER_MODEL    = google/gemma-4-31b-it

DOCUMENT_RANKING_PATCH_PERCENTAGE = 4.0
DOCUMENT_SEARCH_BUFFER_MULTIPLIER = 2

LLAMA_SERVER_URL        = http://localhost:8122

GITLAB_URL=https://your-gitlab-instance.com
GITLAB_PAT=glpat-your-personal-access-token

SUPABASE_TOKEN  = "your-supabase-anon-key"
SUPABASE_URL    = "http://localhost:8000"

OPENAI_API_KEY  = sk-proj-your-openai-api-key
GEMINI_API_KEY  = your-gemini-api-key
SERP_API_KEY    = your-serp-api-key

BVMS_API_TOKEN  = your-bvms-api-token

# ── Code Impact Analyzer — C# Codebase RAG Pipeline ─────────────────────────

# Path to the C# project root (used by Phase 1 indexer and Phase 2 doc writer)
CIA_CODEBASE_PATH        = C:\Gitlab\bbc-bvms-net-back-end-modular

# Files above this line count are sent to the cloud model (default: 200)
CIA_LARGE_FILE_THRESHOLD = 200

# Comma-separated glob patterns — when set, ONLY matching files are processed
# Leave blank to process all files
CIA_FOCUS_ONLY_FILES     =

# Always-excluded paths (Migrations, generated code, build artifacts)
CIA_IGNORE_FILES         = **/Migrations/**,**/*.Designer.cs,**/obj/**,**/bin/**,**/*.Tests/**,**/*.Test/**,**/Tests/**,**/Test/**,**/*Tests.cs,**/*Test.cs,**/*Spec.cs

# Supabase table that stores the C# knowledge vectors
CIA_TABLE_NAME           = n8n_documents_bvms_code

# Path to the pipeline manifest JSON (tracks per-file phase progress)
CIA_MANIFEST_PATH        = wip/csharp-manifest.json

# Path to the codebase index JSON produced by Phase 1
CIA_INDEX_PATH           = wip/csharp-index.json

# Output folders for each pipeline phase (all scoped under wip/ by default)
CIA_RAW_DOCS_FOLDER      = wip/csharp-docs/raw
CIA_ENRICHED_DOCS_FOLDER = wip/csharp-docs/enriched
CIA_WORKFLOWS_FOLDER     = wip/csharp-docs/workflows

# Phase 5 — RAG chunk output folder (no-LLM pre-split of enriched + workflow docs)
CIA_RAG_CHUNKS_FOLDER    = wip/csharp-docs/rag-chunks

# Phase 6 — Done-marker folder (tracks which chunk files have been inserted)
CIA_RAG_DONE_FOLDER      = wip/csharp-docs/rag-done

# Phase 6 — Supabase table for C# codebase knowledge vectors
CIA_RAG_TABLE_NAME       = n8n_documents_csharp

# Seconds to sleep between batches that used cloud models (rate-limit guard)
CIA_CLOUD_BATCH_DELAY    = 2.0

# Number of files processed concurrently per batch
CIA_BATCH_SIZE           = 10

# OpenRouter model used for Phase 2 large-file docs + Phase 4 Pass A synthesis
CIA_OPENROUTER_MODEL      = qwen/qwen3-32b

# OpenRouter model used for Phase 4 Pass B critical deep-dives (best available)
CIA_OPENROUTER_CRITICAL_MODEL       = google/gemini-2.5-pro

# ── OpenRouter concurrency & routing tuning ──────────────────────────────────

# Max concurrent requests sent to OpenRouter at once (default: 3)
# Set to 5 for large codebase analysis (safe with most provider limits)
OPENROUTER_CONCURRENCY   = 1

# Max tokens per response (default: 8192)
# Use 16384 for Phase 2/3 which produce long documentation
OPENROUTER_MAX_TOKENS    = 8192

# Comma-separated preferred provider order for faster routing
# Fireworks/Together are fastest for open models; leave blank to let OpenRouter decide
OPENROUTER_PROVIDER_ORDER = Fireworks,Together,DeepInfra